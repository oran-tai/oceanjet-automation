# Bookaway API
BOOKAWAY_ENV=stage
BOOKAWAY_API_URL_PROD=https://www.bookaway.com/_api
BOOKAWAY_API_URL_STAGE=https://admin-stage.bookaway.com/_api
BOOKAWAY_USERNAME=your.email@bookaway.com
BOOKAWAY_PASSWORD=your_password_here
BOOKAWAY_BOT_IDENTIFIER=automation-bot@bookaway.com

# Polling
POLLING_INTERVAL_MS=30000

# Slack Notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
SLACK_WEBHOOK_URL_2=

# RPA Agent (Windows VM)
RPA_AGENT_URL=http://windows-vm:8080
RPA_AUTH_TOKEN=your_shared_secret_here

# Operator Mode: "mock" or "rpa"
OPERATOR_MODE=mock

# Pacing — random delay between bookings (ms) for human-like throughput
BOOKING_DELAY_MIN_MS=90000
BOOKING_DELAY_MAX_MS=180000
TRIP_NOT_FOUND_COOLDOWN_MS=86400000

# BigQuery Events (optional — leave empty to disable)
BQ_PROJECT_ID=travelier-ai
BQ_KEY_FILE=

# Target a specific booking (optional — leave empty for continuous mode)
TARGET_BOOKING=
